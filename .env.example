# Swipe Merchants API credentials — get these from the Merchant Portal:
# https://merchant.swipe.mv  →  Settings → API Access
# Copy this file to .env.local and fill in real values. Never commit .env.local.
#
# These are SERVER-ONLY secrets — do NOT prefix with NEXT_PUBLIC_ (that would
# inline them into the browser bundle and leak the secret).

SWIPE_CLIENT_ID=
SWIPE_CLIENT_SECRET=

# Webhook HMAC key — Portal → Settings → API Access. Used to verify incoming
# webhook signatures at /api/webhooks/swipe. If unset, webhooks are accepted
# WITHOUT verification (dev only — always set this in production).
SWIPE_WEBHOOK_SECRET=

# Shared store for webhook events. REQUIRED on Vercel: serverless invocations
# don't share memory, so the webhook POST and the browser poll run in different
# lambdas. Provision a Redis store and set these (without them the store is
# in-memory — fine for local dev, not for Vercel):
#   - Vercel → project → Storage → Create Database → Upstash Redis (auto-injects)
#   - or console.upstash.com → Create Database → copy the REST URL + token
# Either naming works (Vercel KV vs Upstash dashboard):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional overrides. Defaults target the production environment, which is the
# environment the above credentials belong to. Leave unset to use the defaults.
# SWIPE_API_BASE=https://api.swipe.mv
# SWIPE_OAUTH_TOKEN_URL=https://api.swipe.mv/oauth2/token
# SWIPE_USER_AGENT=PostmanRuntime/7.39.0
